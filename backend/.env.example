APP_NAME="SenAI CRM Intelligence Platform"
ENVIRONMENT=development
API_PREFIX=/api

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/crm_ai
REDIS_URL=redis://localhost:6379/0

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
MAX_REQUEST_BYTES=1048576
ENABLE_CELERY_DISPATCH=true
EMAIL_PROCESSING_BODY_LIMIT=10000
